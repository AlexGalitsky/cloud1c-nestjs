# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=cloud1c

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# 1C Enterprise
ONEC_PATH=C:\Program Files\1cv8\8.3.18.1208\bin

# 1C RAC (Remote Administration Client) - для создания базы в кластере
RAC_PATH=C:\Program Files\1cv8\8.3.18.1208\bin\rac.exe

# 1C IB Cmd - для восстановления из .dt
IB_CMD_PATH=C:\Program Files\1cv8\8.3.18.1208\bin\ibcmd.exe

# 1C Webinst - для публикации на веб-сервере
WEBINST_PATH=C:\Program Files\1cv8\8.3.18.1208\bin\webinst.exe
WWW_ROOT=C:\inetpub\wwwroot

# 1C Cluster Settings
CLUSTER_ID=9cb5e12a-6233-42fa-8512-d2b59efdc265
CLUSTER_ADDRESS=192.168.1.104
CLUSTER_DBMS=PostgreSQL
CLUSTER_DB_SERVER=192.168.1.72
CLUSTER_DB_USER=postgres
CLUSTER_DB_PASSWORD=SuperPass123
CLUSTER_LOCALE=ru_RU

# 1C InfoBase User/Password (требуется для версий 1С >= 8.3.1741)
# Установите 'true' если ваша версия 1С требует логин/пароль от ИБ
IB_USER_PASS_REQUIRED=false
IB_USER=Admin
IB_PASSWORD=

# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Environment
NODE_ENV=development

